# ── Required API Keys ────────────────────────────────────────
# Browser Use Cloud (get key at cloud.browser-use.com/settings)
BROWSER_USE_API_KEY=bu_your_key_here
BROWSER_USE_MODEL=browser-use-2.0

# OpenAI (for PDF extraction + JSON structuring — no browser)
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini

# SOS browser agent LLM (local browser-use with GPT-4o)
SOS_BROWSER_MODEL=gpt-4o

# ── Browser ─────────────────────────────────────────────────
# Set to false to see browser windows (useful for debugging)
BROWSER_HEADLESS=true

# ── Pool Sizes (concurrent instances per phase) ─────────────
SOS_CONCURRENCY=5
COMPANY_CONCURRENCY=5
PERSON_CONCURRENCY_MAX=10
GLOBAL_BROWSER_CAP=20

# ── Rate Limiting (for OpenAI direct calls only) ────────────
OPENAI_RPM_LIMIT=500

# ── Timeouts (seconds) ──────────────────────────────────────
SOS_TIMEOUT=300
COMPANY_TIMEOUT=180
PERSON_TIMEOUT=180

# ── Agent Step Limits ───────────────────────────────────────
SOS_MAX_STEPS=15
SOS_INTER_ENTITY_DELAY=2.0
COMPANY_MAX_STEPS=10
PERSON_MAX_STEPS=12

# ── Output ──────────────────────────────────────────────────
MAX_CONTACTS=8
JOBS_DIR=./jobs
