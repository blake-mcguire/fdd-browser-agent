# ── Required API Keys ────────────────────────────────────────
# Google Gemini (powers the SOS browser-use agent)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
SOS_BROWSER_MODEL=gemini-2.5-flash

# ── State Portal Credentials (some portals require login) ──
# Michigan LARA portal requires an account
MI_SOS_USER=your_michigan_user_id
MI_SOS_PASS=your_michigan_password

# ── Browser ─────────────────────────────────────────────────
# Set to true to hide browser windows
BROWSER_HEADLESS=false

# ── Pool Sizes ──────────────────────────────────────────────
SOS_CONCURRENCY=3
GLOBAL_BROWSER_CAP=20

# ── Rate Limiting (Gemini) ──────────────────────────────────
GEMINI_RPM_LIMIT=200

# ── Timeouts (seconds) ──────────────────────────────────────
SOS_TIMEOUT=300

# ── SOS Result Validation + Retry ───────────────────────────
# Extra attempts when SOS result fails per-state validation (missing
# required fields, no officers on a state that requires them). On retry
# the failure reason is injected into the task prompt. 0 disables retries.
SOS_VALIDATION_RETRIES=1

# ── Agent Step Limits ───────────────────────────────────────
SOS_MAX_STEPS=15
SOS_INTER_ENTITY_DELAY=2.0

# ── Output ──────────────────────────────────────────────────
JOBS_DIR=./jobs
