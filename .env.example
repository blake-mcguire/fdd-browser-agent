# ── Required API Keys ────────────────────────────────────────
# Google Gemini (SOS browser agent + PDF extraction)
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.5-flash
SOS_BROWSER_MODEL=gemini-2.5-flash

# Browser Use Cloud (company + person agents)
# Get your key at: https://cloud.browser-use.com/settings
BROWSER_USE_API_KEY=bu_your_key_here
BROWSER_USE_MODEL=browser-use-2.0

# ── State Portal Credentials (some portals require login) ──
# Michigan LARA portal requires an account
MI_SOS_USER=your_michigan_user_id
MI_SOS_PASS=your_michigan_password

# ── Browser ─────────────────────────────────────────────────
# Set to true to hide browser windows (SOS agents should run visibly)
BROWSER_HEADLESS=false

# ── Pipeline Toggles ────────────────────────────────────────
# Set to false to stop after SOS (skips company + person enrichment).
# Useful while tuning SOS scrapers without burning enrichment credits.
ENRICHMENT_ENABLED=false

# ── Pool Sizes (concurrent instances per phase) ─────────────
SOS_CONCURRENCY=3
COMPANY_CONCURRENCY=5
PERSON_CONCURRENCY_MAX=10
GLOBAL_BROWSER_CAP=20

# ── Rate Limiting (for Gemini direct extraction calls) ──────
GEMINI_RPM_LIMIT=200

# ── Timeouts (seconds) ──────────────────────────────────────
SOS_TIMEOUT=300
COMPANY_TIMEOUT=180
PERSON_TIMEOUT=180

# ── SOS Result Validation + Retry ───────────────────────────
# Extra attempts when SOS result fails per-state validation (missing
# required fields, no officers on a state that requires them). On retry
# the failure reason is injected into the task prompt. 0 disables retries.
SOS_VALIDATION_RETRIES=1

# ── Agent Step Limits ───────────────────────────────────────
SOS_MAX_STEPS=15
SOS_INTER_ENTITY_DELAY=2.0
COMPANY_MAX_STEPS=10
PERSON_MAX_STEPS=12

# ── Output ──────────────────────────────────────────────────
MAX_CONTACTS=8
JOBS_DIR=./jobs
